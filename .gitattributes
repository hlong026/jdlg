# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to LF line endings on checkout.
*.c text
*.h text
*.cpp text
*.hpp text
*.cc text
*.cxx text
*.hxx text
*.java text
*.py text
*.js text
*.ts text
*.tsx text
*.jsx text
*.go text
*.rs text
*.rb text
*.php text
*.sh text
*.bat text
*.cmd text
*.ps1 text
*.vbs text
*.css text
*.scss text
*.sass text
*.less text
*.html text
*.htm text
*.xml text
*.json text
*.yaml text
*.yml text
*.toml text
*.ini text
*.cfg text
*.conf text
*.md text
*.txt text
*.csv text
*.tsv text

# Declare files that will always have CRLF line endings on checkout.
*.sln text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
