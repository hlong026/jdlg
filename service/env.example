# 环境变量示例：复制后填入实际值（服务从环境变量读取）
# 部署时在系统/容器中设置以下变量即可

# ----- 微信小程序（登录、邀请海报小程序码） -----
WECHAT_APPID=
WECHAT_APPSECRET=

# ----- 企业微信高清图下载配置 -----
ENTERPRISE_WECHAT_DOWNLOAD_4K_QRCODE_URL=
ENTERPRISE_WECHAT_DOWNLOAD_4K_TIP=完成手机号授权验证后，可下载保存高清原图。
# 继续沿用线上现有二维码配置，如需替换再填写新的二维码图片地址
ENTERPRISE_WECHAT_SERVICE_PHONE=13959877676
ENTERPRISE_WECHAT_CUSTOMER_SERVICE_CORP_ID=ww673b3a4edf114110
ENTERPRISE_WECHAT_CUSTOMER_SERVICE_URL=https://work.weixin.qq.com/kfid/kfccb23bfff32bc9c6f

# ----- 腾讯云短信验证码配置 -----
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_LOGIN_TEMPLATE_ID=
TENCENT_SMS_BIND_TEMPLATE_ID=
# 验证码默认 5 分钟有效
TENCENT_SMS_CODE_TTL_SECONDS=300
# 同一手机号发送冷却
TENCENT_SMS_SEND_COOLDOWN_SECONDS=60
# 单个验证码最多尝试次数
TENCENT_SMS_MAX_VERIFY_ATTEMPTS=6
# 单手机号每日发送上限
TENCENT_SMS_MAX_DAILY_SEND_PER_PHONE=20
# 本地/测试环境短信 mock，默认固定验证码 123456
TENCENT_SMS_MOCK_ENABLED=true
TENCENT_SMS_MOCK_CODE=123456
TENCENT_SMS_EXPOSE_MOCK_CODE=true

# ----- AI 接口密钥配置 -----
LAOZHANG_API_KEY=
ARK_API_KEY=
AI_VIDEO_API_BASE_URL=https://api.laozhang.ai
AI_VIDEO_MODEL=veo-3.1-landscape-fast-fl

