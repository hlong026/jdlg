<!--pages/ordermanagement/ordermanagement.wxml-->
<view class="page">
  <!-- 统一导航栏 -->
  <navigation-bar title="订单管理" subtitle="充值 · 消费 · 文创 · 提现" />

  <!-- 顶部统计卡片 -->
  <view class="summary-card">
    <view class="summary-top">
      <view class="summary-item">
        <text class="summary-label">总订单数</text>
        <view class="summary-value-row">
          <t-icon name="file-copy" size="40rpx" color="#b79066" />
          <text class="summary-value">{{totalOrders}}</text>
        </view>
      </view>
      <view class="summary-item">
        <text class="summary-label">总金额（元）</text>
        <view class="summary-value-row">
          <t-icon name="money" size="40rpx" color="#a9855b" />
          <text class="summary-value highlight">￥{{totalAmount}}</text>
        </view>
      </view>
    </view>
    <view class="summary-bottom">
      <view class="summary-item">
        <text class="summary-label">本月订单</text>
        <view class="summary-value-row">
          <t-icon name="calendar" size="40rpx" color="#c39a6b" />
          <text class="summary-value">{{monthOrders}}</text>
        </view>
      </view>
      <view class="summary-item">
        <text class="summary-label">本月金额</text>
        <view class="summary-value-row">
          <t-icon name="chart-bar" size="40rpx" color="#b79066" />
          <text class="summary-value">￥{{monthAmount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-bar">
    <view
      class="filter-tag {{currentType === 'all' ? 'active' : ''}}"
      data-type="all"
      bindtap="onFilterTap"
    >
      <text>全部</text>
    </view>
    <view
      class="filter-tag {{currentType === 'recharge' ? 'active' : ''}}"
      data-type="recharge"
      bindtap="onFilterTap"
    >
      <text>充值</text>
    </view>
    <view
      class="filter-tag {{currentType === 'consume' ? 'active' : ''}}"
      data-type="consume"
      bindtap="onFilterTap"
    >
      <text>消费</text>
    </view>
    <view
      class="filter-tag {{currentType === 'culture' ? 'active' : ''}}"
      data-type="culture"
      bindtap="onFilterTap"
    >
      <text>文创</text>
    </view>
    <view
      class="filter-tag {{currentType === 'withdraw' ? 'active' : ''}}"
      data-type="withdraw"
      bindtap="onFilterTap"
    >
      <text>提现</text>
    </view>
  </view>

  <!-- 内容区 -->
  <view class="content">
    <!-- 加载中 -->
    <view class="loading" wx:if="{{loading}}">
      <t-icon name="loading" size="64rpx" color="#8c7553" class="loading-icon" />
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:elif="{{!loading && orders.length === 0}}">
      <t-icon name="invisible" size="80rpx" color="#8c7553" />
      <text class="empty-title">暂无订单记录</text>
      <text class="empty-desc">订单记录将在这里显示</text>
    </view>

    <!-- 订单列表 -->
    <scroll-view
      wx:else
      class="list-scroll"
      scroll-y="true"
      lower-threshold="60"
      bindscrolltolower="onReachBottom"
    >
      <view
        class="order-item {{item.canDelete ? 'deletable' : ''}}"
        wx:for="{{orders}}"
        wx:key="id"
        bindlongpress="onOrderLongPress"
        data-id="{{item.id}}"
        data-title="{{item.title}}"
        data-can-delete="{{item.canDelete}}"
        data-can-cancel="{{item.canCancel}}"
        data-can-continue-pay="{{item.canContinuePay}}"
      >
        <view class="order-header">
          <view class="order-left">
            <view class="order-icon {{item.type}}">
              <t-icon
                wx:if="{{item.type === 'recharge'}}"
                name="money"
                size="36rpx"
                color="#b79066"
              />
              <t-icon
                wx:elif="{{item.type === 'consume'}}"
                name="edit"
                size="36rpx"
                color="#d37a74"
              />
              <t-icon
                wx:elif="{{item.type === 'culture'}}"
                name="image"
                size="36rpx"
                color="#b79066"
              />
              <t-icon
                wx:elif="{{item.type === 'withdraw'}}"
                name="wallet"
                size="36rpx"
                color="#a9855b"
              />
              <t-icon
                wx:else
                name="file-copy"
                size="36rpx"
                color="#8c7553"
              />
            </view>
            <view class="order-info">
              <text class="order-title">{{item.title}}</text>
              <text class="order-subtitle">{{item.orderNo}}</text>
            </view>
          </view>
          <view class="order-header-right">
            <text class="order-delete-badge" wx:if="{{item.canDelete}}">长按可删除</text>
            <view class="order-status {{item.status}}">
              <text class="status-text">{{item.statusText}}</text>
            </view>
          </view>
        </view>

        <view class="order-body">
          <view class="order-detail-row">
            <text class="detail-label">订单类型</text>
            <text class="detail-value">{{item.typeText}}</text>
          </view>
          <view class="order-detail-row">
            <text class="detail-label">评价状态</text>
            <text class="detail-value review-status {{item.reviewStatus}}">{{item.reviewStatusText}}</text>
          </view>
          <view class="order-detail-row" wx:if="{{item.description}}">
            <text class="detail-label">订单描述</text>
            <text class="detail-value">{{item.description}}</text>
          </view>
          <view class="order-detail-row" wx:if="{{item.completedAt}}">
            <text class="detail-label">完成时间</text>
            <text class="detail-value">{{item.completedAt}}</text>
          </view>
          <view class="order-detail-row">
            <text class="detail-label">订单时间</text>
            <text class="detail-value">{{item.time}}</text>
          </view>
        </view>

        <view class="order-footer">
          <view class="order-amount-row">
            <text class="amount-label">订单金额</text>
            <text class="amount-value {{item.amount > 0 ? 'plus' : 'minus'}}">
              {{item.amount > 0 ? '+' : ''}}￥{{item.amountText}}
            </text>
          </view>
          <text class="order-longpress-tip" wx:if="{{item.canDelete}}">长按卡片可删除该订单记录</text>
          <view class="order-actions" wx:if="{{item.canAction}}">
            <view class="action-btn" bindtap="onViewOrder" data-id="{{item.id}}">
              <text>查看详情</text>
            </view>
            <view class="action-btn primary" wx:if="{{item.canContinuePay}}" bindtap="onContinueCertificationPay" data-id="{{item.id}}" data-order-no="{{item.orderNo}}">
              <text>继续支付</text>
            </view>
            <view class="action-btn review" wx:if="{{item.canReview}}" bindtap="openReviewModal" data-id="{{item.id}}" data-title="{{item.title}}">
              <text>去评价</text>
            </view>
            <view class="action-btn primary" wx:if="{{item.canCancel}}" bindtap="onCancelOrder" data-id="{{item.id}}">
              <text>取消订单</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{hasMore && !loadingMore}}">
        <text class="load-more-text">上滑加载更多</text>
      </view>
      <view class="load-more" wx:if="{{loadingMore}}">
        <t-icon name="loading" size="40rpx" color="#8c7553" class="loading-icon" />
        <text class="load-more-text">正在加载...</text>
      </view>
      <view class="load-more" wx:if="{{!hasMore && orders.length > 0}}">
        <text class="load-more-text">已加载全部订单</text>
      </view>
    </scroll-view>
  </view>

  <view class="review-modal-mask" wx:if="{{showReviewModal}}" bindtap="closeReviewModal">
    <view class="review-modal" catchtap="onReviewModalContentTap">
      <view class="review-modal-header">
        <text class="review-modal-title">订单评价</text>
        <text class="review-modal-subtitle">{{reviewForm.orderTitle}}</text>
      </view>

      <view class="review-stars-row">
        <view class="review-star-item {{reviewForm.rating >= 1 ? 'active' : ''}}" bindtap="onReviewStarTap" data-rating="1">★</view>
        <view class="review-star-item {{reviewForm.rating >= 2 ? 'active' : ''}}" bindtap="onReviewStarTap" data-rating="2">★</view>
        <view class="review-star-item {{reviewForm.rating >= 3 ? 'active' : ''}}" bindtap="onReviewStarTap" data-rating="3">★</view>
        <view class="review-star-item {{reviewForm.rating >= 4 ? 'active' : ''}}" bindtap="onReviewStarTap" data-rating="4">★</view>
        <view class="review-star-item {{reviewForm.rating >= 5 ? 'active' : ''}}" bindtap="onReviewStarTap" data-rating="5">★</view>
      </view>

      <textarea class="review-textarea" value="{{reviewForm.content}}" bindinput="onReviewContentInput" maxlength="1024" placeholder="说说这次设计服务体验，帮助更多用户了解设计师"></textarea>

      <view class="review-modal-actions">
        <button class="review-btn secondary" bindtap="closeReviewModal" disabled="{{reviewSubmitting}}">取消</button>
        <button class="review-btn primary" bindtap="submitReview" loading="{{reviewSubmitting}}" disabled="{{reviewSubmitting}}">提交评价</button>
      </view>
    </view>
  </view>
</view>