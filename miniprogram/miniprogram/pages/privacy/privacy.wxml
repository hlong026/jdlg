<view class="page">
  <!-- 统一导航栏 -->
  <navigation-bar title="隐私政策" subtitle="更新日期 {{updateDate}}" />

  <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="false">
    <view class="content">
      <view class="hero-card">
        <text class="hero-title">感谢你使用甲第灵光</text>
        <text class="hero-desc">为了向你提供登录、安全校验、AI生成、订单与客户服务，我们会在必要范围内收集和使用相关信息，并严格按照本政策进行处理。</text>
        <text class="hero-tip" wx:if="{{from === 'login'}}">你需要先阅读并同意本政策后，才可以继续登录。</text>
      </view>

      <view class="policy-card" wx:for="{{sections}}" wx:key="title">
        <text class="section-title">{{item.title}}</text>
        <view class="section-list">
          <view class="section-item" wx:for="{{item.items}}" wx:key="*this">
            <text class="section-dot"></text>
            <text class="section-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="policy-card contact-card">
        <text class="section-title">六、联系我们</text>
        <view class="contact-item" wx:for="{{contactItems}}" wx:key="label">
          <text class="contact-label">{{item.label}}</text>
          <text class="contact-value">{{item.value}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
