<!--index.wxml-->
<view class="pages">
  <view class="home-canvas">
    <image class="bg-image" src="{{heroBgImage}}" mode="scaleToFill" />
    <image class="daily-checkin" src="{{dailyCheckinImage}}" mode="scaleToFill" bindtap="onOpenPage" data-url="/pages/checkin/checkin?source=index" />
    <image class="invite-friend" src="{{inviteFriendImage}}" mode="scaleToFill" bindtap="onOpenPage" data-url="/pages/Invitefriends/Invitefriends?source=index" />

    <image class="core-entry" src="{{coreEntryImage}}" mode="scaleToFill" />
    <view class="hotspot photo-hotspot" bindtap="onOpenPage" data-url="/pages/aigenerate/aigenerate?source=index"></view>
    <view class="hotspot voice-hotspot" bindtap="onOpenPage" data-url="/pages/aitools/aitools"></view>

    <image class="service-card rural-card" src="{{ruralVillaImage}}" mode="scaleToFill" bindtap="onOpenPage" data-url="/pages/aigenerate/aigenerate?source=rural_villa&showSceneTabs=1&tab=exterior" />
    <image class="service-card city-card" src="{{cityRenewalImage}}" mode="scaleToFill" bindtap="onOpenPage" data-url="/pages/aigenerate/aigenerate?source=urban_renewal&showSceneTabs=0" />
    <image class="service-card parent-card" src="{{parentWorkshopImage}}" mode="scaleToFill" bindtap="onOpenPage" data-url="/pages/Parentchildcreativity/Parentchildcreativity" />
    <image class="service-card all-card" src="{{allRoundDesignImage}}" mode="scaleToFill" bindtap="onOpenPage" data-url="/pages/allrounddesign/allrounddesign" />
  </view>
  <view class="content">
    <view class="case-section" wx:if="{{featuredGroups && featuredGroups.length > 0}}">
      <text class="case-title">精选案例对比</text>
      <view class="featured-groups">
        <view class="featured-group" wx:for="{{featuredGroups}}" wx:key="id">
          <view class="case-comparison" wx:if="{{item.display_mode === 'comparison'}}">
            <view class="case-card" wx:if="{{item.case1}}">
              <view class="case-item" bindtap="onFeaturedCaseTap" data-id="{{item.case1.id}}">
                <view class="case-image-wrapper">
                  <text class="case-label">{{item.case1_label}}</text>
                  <image class="case-image" src="{{item.case1.thumbnail || item.case1.preview_url || defaultCoverImage}}" mode="widthFix"></image>
                </view>
                <view class="case-content">
                  <text class="case-item-title">{{item.case1.name}}</text>
                  <text class="case-item-desc">{{item.case1.description || '通过AI技术，将真实场景快速转换为专业设计方案'}}</text>
                </view>
              </view>
            </view>
            <view class="vs-divider" wx:if="{{item.case1 && item.case2}}">VS</view>
            <view class="case-card" wx:if="{{item.case2}}">
              <view class="case-item" bindtap="onFeaturedCaseTap" data-id="{{item.case2.id}}">
                <view class="case-image-wrapper">
                  <text class="case-label">{{item.case2_label}}</text>
                  <image class="case-image" src="{{item.case2.thumbnail || item.case2.preview_url || defaultCoverImage}}" mode="widthFix"></image>
                </view>
                <view class="case-content">
                  <text class="case-item-title">{{item.case2.name}}</text>
                  <text class="case-item-desc">{{item.case2.description || '通过AI技术，将真实场景快速转换为专业设计方案'}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="case-side-by-side" wx:elif="{{item.display_mode === 'side_by_side'}}">
            <view class="case-card" wx:if="{{item.case1}}">
              <view class="case-item" bindtap="onFeaturedCaseTap" data-id="{{item.case1.id}}">
                <view class="case-image-wrapper">
                  <text class="case-label">{{item.case1_label}}</text>
                  <image class="case-image" src="{{item.case1.thumbnail || item.case1.preview_url || defaultCoverImage}}" mode="widthFix"></image>
                </view>
                <view class="case-content">
                  <text class="case-item-title">{{item.case1.name}}</text>
                  <text class="case-item-desc">{{item.case1.description || '通过AI技术，将真实场景快速转换为专业设计方案'}}</text>
                </view>
              </view>
            </view>
            <view class="case-card" wx:if="{{item.case2}}">
              <view class="case-item" bindtap="onFeaturedCaseTap" data-id="{{item.case2.id}}">
                <view class="case-image-wrapper">
                  <text class="case-label">{{item.case2_label}}</text>
                  <image class="case-image" src="{{item.case2.thumbnail || item.case2.preview_url || defaultCoverImage}}" mode="widthFix"></image>
                </view>
                <view class="case-content">
                  <text class="case-item-title">{{item.case2.name}}</text>
                  <text class="case-item-desc">{{item.case2.description || '通过AI技术，将真实场景快速转换为专业设计方案'}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="case-normal" wx:elif="{{item.display_mode === 'normal'}}">
            <view class="case-card" wx:if="{{item.case1}}">
              <view class="case-item" bindtap="onFeaturedCaseTap" data-id="{{item.case1.id}}">
                <view class="case-image-wrapper">
                  <image class="case-image" src="{{item.case1.thumbnail || item.case1.preview_url || defaultCoverImage}}" mode="widthFix"></image>
                </view>
                <view class="case-content">
                  <text class="case-item-title">{{item.case1.name}}</text>
                  <text class="case-item-desc">{{item.case1.description || '通过AI技术，将真实场景快速转换为专业设计方案'}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="case-actions">
        <view class="action-btn" bindtap="onViewLocalSpec">
          <text>查看本地规范</text>
        </view>
        <view class="action-btn" bindtap="onContactService">
          <text>联系服务商</text>
        </view>
      </view>
    </view>
    <view class="case-section case-section-skeleton" wx:elif="{{featuredGroupsLoading}}">
      <view class="case-title skeleton-block skeleton-title"></view>
      <view class="featured-groups skeleton-groups">
        <view class="skeleton-group-row">
          <view class="skeleton-card"></view>
          <view class="skeleton-card"></view>
        </view>
        <view class="skeleton-group-row">
          <view class="skeleton-card skeleton-card-wide"></view>
        </view>
      </view>
      <view class="case-actions">
        <view class="action-btn skeleton-action"></view>
        <view class="action-btn skeleton-action"></view>
      </view>
    </view>
  </view>

  <view wx:if="{{contactPopupVisible}}" class="popup-mask" bindtap="closeContactPopup">
    <view class="contact-popup" catchtap="noop">
      <view class="popup-header">
        <view class="popup-header-main">
          <text class="popup-title">联系服务商</text>
          <text class="popup-subtitle">选择更适合你的沟通方式，快速获得帮助</text>
        </view>
        <view class="popup-close" bindtap="closeContactPopup">×</view>
      </view>

      <!-- 在线客服（小程序原生客服） -->
      <view class="supplier-option supplier-option-contact">
        <view class="supplier-option-icon supplier-chat-icon">💬</view>
        <view class="supplier-option-content">
          <text class="supplier-option-title">在线客服</text>
          <text class="supplier-option-desc">在线消息咨询</text>
        </view>
        <view class="supplier-option-right">
          <text class="supplier-option-badge green">立即咨询</text>
          <text class="supplier-option-arrow">›</text>
        </view>
        <button class="supplier-option-contact-btn" open-type="contact" bindcontact="onNativeContactSuccess"></button>
      </view>

      <!-- 电话咨询 -->
      <view class="supplier-option" bindtap="onCallSupplier">
        <view class="supplier-option-icon supplier-phone-icon">☎</view>
        <view class="supplier-option-content">
          <text class="supplier-option-title">电话咨询</text>
          <text class="supplier-option-desc">{{supplierPhone}}</text>
        </view>
        <view class="supplier-option-right">
          <text class="supplier-option-badge warm">立即联系</text>
          <text class="supplier-option-arrow">›</text>
        </view>
      </view>

      <!-- 智能客服（企微客服，失败弹二维码） -->
      <view class="supplier-option" bindtap="onSmartServiceTap">
        <view class="supplier-option-icon supplier-ai-icon">🤖</view>
        <view class="supplier-option-content">
          <text class="supplier-option-title">智能客服</text>
          <text class="supplier-option-desc">AI 智能问答</text>
        </view>
        <view class="supplier-option-right">
          <text class="supplier-option-badge green">立即体验</text>
          <text class="supplier-option-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{wechatPopupVisible}}" class="popup-mask" bindtap="closeWechatQrcode">
    <view class="wechat-popup" catchtap="noop">
      <view class="popup-header">
        <view class="popup-header-main">
          <text class="popup-title">企业微信咨询</text>
          <text class="popup-subtitle">长按识别二维码，添加后可继续一对一沟通与服务跟进</text>
        </view>
        <view class="popup-close" bindtap="closeWechatQrcode">×</view>
      </view>

      <view class="wechat-summary-card">
        <view class="wechat-summary-icon">微</view>
        <view class="wechat-summary-content">
          <text class="wechat-summary-title">企业微信在线咨询</text>
          <text class="wechat-summary-desc">当前为二维码备用入口，若直达客服未拉起，可长按识别继续咨询</text>
        </view>
      </view>

      <view class="wechat-qrcode-wrapper">
        <image wx:if="{{supplierWechatQrAvailable}}" class="wechat-qrcode-image" src="{{supplierWechatQr}}" mode="aspectFit" binderror="onWechatQrcodeError" bindtap="previewWechatQrcode" />
        <view wx:else class="wechat-qrcode-placeholder">
          <text class="wechat-qrcode-placeholder-title">请补充客服二维码图片</text>
          <text class="wechat-qrcode-placeholder-desc">将二维码图片放到 /assets/企业微信二维码.png</text>
        </view>
      </view>

      <view class="wechat-service-tip">
        <text class="wechat-service-tip-text">{{enterpriseWechatTip}}</text>
      </view>

      <view class="wechat-popup-footer">
        <view class="wechat-footer-btn secondary" bindtap="closeWechatQrcode">稍后再看</view>
        <view class="wechat-footer-btn primary" bindtap="previewWechatQrcode">查看大图</view>
      </view>
    </view>
  </view>
</view>