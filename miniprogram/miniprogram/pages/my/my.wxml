<!--pages/my/my.wxml-->
<view class="page">
  <!-- 隐藏的canvas用于生成设备指纹 -->
  <canvas 
    id="device-fingerprint-canvas" 
    type="2d" 
    style="position: fixed; left: -9999px; width: 100px; height: 100px;"
  ></canvas>
  <image class="page-background" src="{{pageBgImage}}" mode="widthFix" />

  <!-- 统一导航栏（Tab页不显示返回按钮） -->
  <navigation-bar back="{{false}}" />

  <!-- 用户资料区域 -->
  <view class="page-content">
    <view class="profile-section">
      <view class="user-profile" bindtap="onProfileTap">
        <image class="avatar" src="{{userProfile.avatar || defaultAvatarImage}}" mode="aspectFill" />
        <view class="user-info">
          <text class="nickname">{{userProfile.nickname || (userInfo ? userInfo.username : (hasLoginToken ? '加载中...' : '未登录'))}}</text>
          <view class="vip-tags">
            <view class="vip-tag vip-tag-dark">
              <text>会员等级</text>
            </view>
            <view class="vip-tag vip-tag-light">
              <text>{{vipLevelText}}</text>
            </view>
          </view>
          <!-- 认证信息：已认证时展示实名和身份 -->
          <view class="cert-info" wx:if="{{certStatus === 'approved'}}">
            <text class="cert-badge">已认证</text>
            <text class="cert-text">{{certRealName || certRealNameMasked}}{{certIdentityType ? ' · ' + certIdentityType : ''}}</text>
          </view>
          <view class="login-hint" wx:if="{{!hasLoginToken}}">点击登录后查看完整信息</view>
        </view>
      </view>
      <view class="check-in-button" bindtap="onCheckInTap">
        <image class="check-in-image" src="{{checkInImage}}" mode="widthFix" />
      </view>
    </view>

    <view class="content">
      <!-- 数据展示区域 -->
      <view class="stats-card">
        <view class="stats-item">
          <text class="stats-value">{{vipLevelShortDisplay}}</text>
          <text class="stats-label">会员等级</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item" bindtap="goToGenerateHistory">
          <text class="stats-value">{{taskCount || 0}}</text>
          <text class="stats-label">生成记录</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item" bindtap="goToWallet">
          <text class="stats-value">{{stonesDisplay || 0}}</text>
          <text class="stats-label">灵石余额</text>
        </view>
      </view>

      <!-- 未登录提示 -->
      <view class="login-prompt" wx:if="{{!hasLoginToken}}">
        <text class="prompt-text">请先登录后查看会员与账户信息</text>
      </view>

      <view class="menu-section-title">常用功能</view>
      <view class="menu-card menu-list-card project-card">
        <view
          wx:for="{{commonMenuItems}}"
          wx:key="action"
          class="menu-list-item {{index === commonMenuItems.length - 1 ? 'menu-list-item-last' : ''}}"
          bindtap="onProjectMenuTap"
          data-action="{{item.action}}"
        >
          <view class="menu-list-main">
            <view class="menu-list-icon">
              <text>{{item.shortLabel}}</text>
            </view>
            <text class="menu-list-label">{{item.label}}</text>
          </view>
          <view class="menu-list-tail">
            <text class="menu-list-meta" wx:if="{{item.meta}}">{{item.meta}}</text>
            <text class="menu-list-arrow">›</text>
          </view>
        </view>
      </view>

      <view class="menu-section-title">设计师工作台</view>
      <view class="menu-card menu-list-card account-card">
        <view
          wx:for="{{workbenchMenuItems}}"
          wx:key="action"
          class="menu-list-item {{index === workbenchMenuItems.length - 1 ? 'menu-list-item-last' : ''}}"
          bindtap="onWorkbenchMenuTap"
          data-action="{{item.action}}"
        >
          <view class="menu-list-main">
            <view class="menu-list-icon menu-list-icon-secondary">
              <text>{{item.shortLabel}}</text>
            </view>
            <text class="menu-list-label">{{item.label}}</text>
          </view>
          <view class="menu-list-tail">
            <text class="menu-list-meta" wx:if="{{item.meta}}">{{item.meta}}</text>
            <text class="menu-list-arrow">›</text>
          </view>
        </view>
      </view>

      <view class="menu-section-title">账户与工具</view>
      <view class="menu-card menu-list-card account-card">
        <view
          wx:for="{{serviceMenuItems}}"
          wx:key="action"
          class="menu-list-item {{index === serviceMenuItems.length - 1 ? 'menu-list-item-last' : ''}}"
          bindtap="onAccountMenuTap"
          data-action="{{item.action}}"
        >
          <view class="menu-list-main">
            <view class="menu-list-icon menu-list-icon-secondary">
              <text>{{item.shortLabel}}</text>
            </view>
            <text class="menu-list-label">{{item.label}}</text>
          </view>
          <view class="menu-list-tail">
            <text class="menu-list-meta" wx:if="{{item.meta}}">{{item.meta}}</text>
            <text class="menu-list-arrow">›</text>
          </view>
        </view>
      </view>

      <view class="logout-btn" wx:if="{{hasLoginToken}}" bindtap="onLogoutTap">退出登录</view>
    </view>
  </view>
</view>
