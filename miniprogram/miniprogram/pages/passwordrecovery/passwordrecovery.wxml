<view class="page">
  <!-- 统一导航栏 -->
  <navigation-bar title="找回密码" subtitle="通过微信手机号验证重置登录密码" background="#e6daca" />

  <view class="content">
    <view class="form-card">
      <view class="page-tip">
        <text>请填写账号用户名，并使用该账号已经验证过的微信手机号完成身份校验。</text>
      </view>

      <view class="form-group">
        <view class="input-wrapper">
          <t-icon name="user" size="40rpx" color="#b79066" />
          <input
            class="form-input"
            type="text"
            placeholder="请输入用户名"
            placeholder-class="input-placeholder"
            value="{{username}}"
            bindinput="onUsernameInput"
            disabled="{{loading}}"
          />
        </view>
      </view>

      <view class="form-group">
        <view class="input-wrapper">
          <t-icon name="lock-on" size="40rpx" color="#b79066" />
          <input
            class="form-input"
            type="password"
            password="{{true}}"
            placeholder="请输入新密码（至少6位）"
            placeholder-class="input-placeholder"
            value="{{newPassword}}"
            bindinput="onNewPasswordInput"
            disabled="{{loading}}"
          />
        </view>
      </view>

      <view class="form-group">
        <view class="input-wrapper">
          <t-icon name="lock-on" size="40rpx" color="#b79066" />
          <input
            class="form-input"
            type="password"
            password="{{true}}"
            placeholder="请再次输入新密码"
            placeholder-class="input-placeholder"
            value="{{confirmPassword}}"
            bindinput="onConfirmPasswordInput"
            disabled="{{loading}}"
          />
        </view>
      </view>

      <view class="hint-card">
        <view class="hint-row">1. 该账号需先在系统里完成过手机号验证</view>
        <view class="hint-row">2. 点击下方按钮后，微信会弹出手机号授权确认</view>
        <view class="hint-row">3. 验证通过后会直接重置为你当前填写的新密码</view>
      </view>

      <button
        class="login-button password-button"
        open-type="getPhoneNumber"
        bindgetphonenumber="handlePhoneRecovery"
        disabled="{{loading || !canSubmit}}"
        loading="{{loading}}"
      >
        {{loading ? '验证中...' : '验证手机号并重置密码'}}
      </button>
    </view>
  </view>
</view>
