<!--pages/aicost/aicost.wxml-->
<view class="page">
  <navigation-bar title="造价生成" background="#e6daca" />

  <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="hero-card">
      <text class="hero-title">建房造价快速测算</text>
      <text class="hero-desc">填写基础参数，先得到一个低于常规造价约 30% 的参考价，再联系服务商确认落地方案。</text>
    </view>

    <view class="form-section">
      <view class="section-title">基础信息</view>
      <view class="section-content">
        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">省份</text>
            <input class="form-input" value="{{province}}" bindinput="onProvinceInput" placeholder="如 福建" />
          </view>
          <view class="form-item half">
            <text class="form-label">城市</text>
            <input class="form-input" value="{{city}}" bindinput="onCityInput" placeholder="如 福州" />
          </view>
        </view>

        <view class="form-row">
          <view class="form-item half">
            <text class="form-label">建筑面积</text>
            <view class="form-input-group">
              <input class="form-input" type="digit" value="{{buildingArea}}" bindinput="onBuildingAreaInput" placeholder="如 320" />
              <text class="form-unit">㎡</text>
            </view>
          </view>
          <view class="form-item half">
            <text class="form-label">楼层高度</text>
            <view class="form-input-group">
              <input class="form-input" type="digit" value="{{floorHeight}}" bindinput="onFloorHeightInput" placeholder="如 3.3" />
              <text class="form-unit">m</text>
            </view>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">屋顶形式</text>
          <view class="form-select" bindtap="onSelectOption" data-field="roofType" data-options="roofOptions">
            <text class="select-text">{{roofType}}</text>
            <t-icon name="chevron-down" size="32rpx" color="#8c7553" />
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">地下室形式</text>
          <view class="form-select" bindtap="onSelectOption" data-field="basementType" data-options="basementOptions">
            <text class="select-text">{{basementType}}</text>
            <t-icon name="chevron-down" size="32rpx" color="#8c7553" />
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">装修风格</text>
          <view class="form-select" bindtap="onSelectOption" data-field="decorationStyle" data-options="decorationOptions">
            <text class="select-text">{{decorationStyle}}</text>
            <t-icon name="chevron-down" size="32rpx" color="#8c7553" />
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">外立面样式</text>
          <view class="form-select" bindtap="onSelectOption" data-field="facadeStyle" data-options="facadeOptions">
            <text class="select-text">{{facadeStyle}}</text>
            <t-icon name="chevron-down" size="32rpx" color="#8c7553" />
          </view>
        </view>
      </view>
    </view>

    <view class="submit-section">
      <button class="submit-btn" bindtap="onEstimateCost">生成参考造价</button>
    </view>

    <view class="result-section" wx:if="{{hasEstimate}}">
      <view class="result-head">
        <text class="result-label">参考测算价</text>
        <text class="result-amount">{{estimatedTotalCost}}</text>
        <text class="result-sub">约 {{estimatedUnitCost}} · 已按常规造价 7 折测算</text>
      </view>
      <view class="result-compare">
        <text>常规估算：{{normalTotalCost}}</text>
        <text>当前方案价约低 30%</text>
      </view>
      <view class="result-actions">
        <button class="detail-btn" bindtap="onViewCostDetails">{{showCostDetails ? '收起费用明细' : '查看费用明细'}}</button>
        <button class="contact-btn" bindtap="onContactService">联系客服</button>
      </view>
    </view>

    <view class="cost-breakdown" wx:if="{{hasEstimate && showCostDetails}}">
      <view class="section-title">常见分项工程造价</view>
      <view class="breakdown-list">
        <view class="breakdown-item" wx:for="{{costBreakdown}}" wx:key="name">
          <view class="breakdown-main">
            <text class="breakdown-name">{{item.name}}</text>
            <text class="breakdown-amount">{{item.amount}}</text>
          </view>
          <text class="breakdown-note">{{item.note}}</text>
        </view>
      </view>
      <view class="breakdown-tip">以上为快速估算结果，最终价格需结合地勘、结构、材料品牌和施工范围确认。</view>
    </view>
  </scroll-view>
</view>
