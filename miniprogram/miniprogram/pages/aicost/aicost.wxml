<view class="page">
  <navigation-bar title="造价生成" background="#eadfce" />

  <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="hero-section">
      <text class="hero-kicker">AI Cost Studio</text>
      <text class="hero-title">造价生成</text>
      <text class="hero-desc">输入建房参数后，系统会生成建筑基础、建筑主体、外观装修、室内装修、花园庭院五大分项测算表。</text>
      <view class="hero-pills">
        <text class="hero-pill">基础</text>
        <text class="hero-pill">主体</text>
        <text class="hero-pill">外装</text>
        <text class="hero-pill">内装</text>
        <text class="hero-pill">庭院</text>
      </view>
    </view>

    <view class="guide-grid">
      <view class="guide-item">
        <text class="guide-step">01</text>
        <text class="guide-title">填写参数</text>
        <text class="guide-desc">补充城市、面积、层数和结构偏好。</text>
      </view>
      <view class="guide-item">
        <text class="guide-step">02</text>
        <text class="guide-title">提交生成</text>
        <text class="guide-desc">系统将按造价逻辑拆解生成测算表。</text>
      </view>
      <view class="guide-item">
        <text class="guide-step">03</text>
        <text class="guide-title">历史查看</text>
        <text class="guide-desc">完成后可在生成历史中获取 Excel 链接。</text>
      </view>
    </view>

    <view class="form-section doc-section">
      <view class="section-header">
        <text class="section-title">项目参数</text>
        <text class="section-desc">建议先完成城市、占地、层数，再补充宽深和扣减项。</text>
      </view>

      <view class="section-content">
        <view class="field-grid">
          <view class="form-item field-span-2">
            <text class="form-label">所在城市</text>
            <view class="form-input-group">
              <input class="form-input" type="text" value="{{city}}" bindinput="onCityInput" placeholder="请输入省 / 市" />
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">房屋面宽</text>
            <view class="form-input-group">
              <input class="form-input" type="digit" value="{{houseWidth}}" bindinput="onHouseWidthInput" placeholder="0" />
              <text class="form-unit">米</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">进深</text>
            <view class="form-input-group">
              <input class="form-input" type="digit" value="{{houseDepth}}" bindinput="onHouseDepthInput" placeholder="0" />
              <text class="form-unit">米</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">占地</text>
            <view class="form-input-group">
              <input class="form-input" type="digit" value="{{areaBuild}}" bindinput="onAreaBuildInput" placeholder="0" />
              <text class="form-unit">m²</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">层数</text>
            <view class="form-input-group">
              <input class="form-input" type="number" value="{{floors}}" bindinput="onFloorsInput" placeholder="0" />
              <text class="form-unit">层</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">花园面积</text>
            <view class="form-input-group">
              <input class="form-input" type="digit" value="{{areaGarden}}" bindinput="onAreaGardenInput" placeholder="0" />
              <text class="form-unit">m²</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">扣除庭院</text>
            <view class="form-input-group">
              <input class="form-input" type="digit" value="{{courtyardDeduct}}" bindinput="onCourtyardDeductInput" placeholder="0" />
              <text class="form-unit">m²</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">露台扣减</text>
            <view class="form-input-group">
              <input class="form-input" type="digit" value="{{terraceDeduct}}" bindinput="onTerraceDeductInput" placeholder="0" />
              <text class="form-unit">m²</text>
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">结构形式</text>
            <view class="form-select" bindtap="onSelectStructure">
              <text class="select-text">{{structureType || '砖混结构'}}</text>
              <t-icon name="chevron-down" size="32rpx" color="#8c7553" />
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">屋顶形式</text>
            <view class="form-select" bindtap="onSelectRoof">
              <text class="select-text">{{roofType || '坡屋顶'}}</text>
              <t-icon name="chevron-down" size="32rpx" color="#8c7553" />
            </view>
          </view>

          <view class="form-item">
            <text class="form-label">地下室</text>
            <view class="form-select" bindtap="onSelectBasement">
              <text class="select-text">{{basement || '无'}}</text>
              <t-icon name="chevron-down" size="32rpx" color="#8c7553" />
            </view>
          </view>
        </view>
      </view>

      <view class="submit-section">
        <button class="submit-btn" bindtap="onSubmitDoc" disabled="{{submittingDoc}}">
          {{submittingDoc ? '提交中...' : '生成测算表'}}
        </button>
      </view>

      <view class="secondary-actions">
        <view class="secondary-btn" bindtap="onOpenGenerateHistory">
          <text>查看生成历史</text>
        </view>
      </view>

      <view class="doc-tip" wx:if="{{docTaskNo}}">
        <text>任务号：{{docTaskNo}}，可前往生成历史查看进度。</text>
      </view>
    </view>
  </scroll-view>
</view>
