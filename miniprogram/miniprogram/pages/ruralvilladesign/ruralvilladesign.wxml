<!--pages/ruralvilladesign/ruralvilladesign.wxml-->
<view class="page">
  <!-- 统一导航栏 -->
  <navigation-bar title="乡村别墅AI设计" background="#e6daca" />

  <view class="content">
    <!-- 步骤1: 尺寸选择（可折叠） -->
    <view class="collapsible-section">
      <view class="collapsible-item {{expandedSections.size ? 'expanded' : ''}}" bindtap="onToggleSection" data-section="size">
        <view class="step-header">
          <text class="step-number">1</text>
          <text class="collapsible-title">尺寸选择</text>
          <text class="step-status" wx:if="{{stepCompleted.size}}">✓</text>
        </view>
        <t-icon name="{{expandedSections.size ? 'chevron-down' : 'chevron-up'}}" size="32rpx" color="#8c7553" />
      </view>
      <view class="collapsible-content" wx:if="{{expandedSections.size}}">
        <!-- 标准模板 -->
        <view class="section">
          <text class="section-label">标准模板</text>
          <view class="template-buttons">
            <view class="template-btn {{selectedTemplate === item.value ? 'active' : ''}}" 
                  wx:for="{{templates}}" 
                  wx:key="index"
                  bindtap="onSelectTemplate"
                  data-value="{{item.value}}">
              {{item.label}}
            </view>
          </view>
        </view>

        <!-- 自定义输入 -->
        <view class="section">
          <text class="section-label">自定义输入</text>
          <view class="input-group">
            <view class="input-item">
              <text class="input-label">长</text>
              <input class="input-field" type="digit" value="{{customLength}}" bindinput="onLengthInput" placeholder="0" />
            </view>
            <view class="input-item">
              <text class="input-label">宽</text>
              <input class="input-field" type="digit" value="{{customWidth}}" bindinput="onWidthInput" placeholder="0" />
            </view>
            <view class="input-item">
              <text class="input-label">面积</text>
              <input class="input-field" type="digit" value="{{customArea}}" bindinput="onAreaInput" placeholder="0" />
              <text class="input-unit">毫米</text>
            </view>
          </view>
        </view>

        <!-- 上传按钮 -->
        <view class="upload-btn" bindtap="onUploadSize">
          <t-icon name="upload" size="36rpx" color="#8c7553" />
          <text>上传地形图/简图照片</text>
        </view>
        <view class="uploaded-images" wx:if="{{sizeImages.length > 0}}">
          <view class="image-item" wx:for="{{sizeImages}}" wx:key="index">
            <image class="uploaded-image" src="{{item}}" mode="aspectFill" />
            <view class="image-delete" bindtap="onDeleteSizeImage" data-index="{{index}}">×</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 步骤2: 风格选择 -->
    <view class="collapsible-section">
      <view class="collapsible-item {{expandedSections.style ? 'expanded' : ''}}" bindtap="onToggleSection" data-section="style">
        <view class="step-header">
          <text class="step-number">2</text>
          <text class="collapsible-title">风格选择</text>
          <text class="step-status" wx:if="{{stepCompleted.style}}">✓</text>
        </view>
        <t-icon name="{{expandedSections.style ? 'chevron-down' : 'chevron-up'}}" size="32rpx" color="#8c7553" />
      </view>
      <view class="collapsible-content" wx:if="{{expandedSections.style}}">
        <view class="style-options">
          <view class="style-item {{selectedStyle === item.value ? 'active' : ''}}" 
                wx:for="{{styleOptions}}" 
                wx:key="index"
                bindtap="onSelectStyle"
                data-value="{{item.value}}">
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 步骤3: 地块补充 -->
    <view class="collapsible-section">
      <view class="collapsible-item {{expandedSections.plot ? 'expanded' : ''}}" bindtap="onToggleSection" data-section="plot">
        <view class="step-header">
          <text class="step-number">3</text>
          <text class="collapsible-title">地块补充</text>
          <text class="step-status" wx:if="{{stepCompleted.plot}}">✓</text>
        </view>
        <t-icon name="{{expandedSections.plot ? 'chevron-down' : 'chevron-up'}}" size="32rpx" color="#8c7553" />
      </view>
      <view class="collapsible-content" wx:if="{{expandedSections.plot}}">
        <view class="plot-form">
          <view class="form-item">
            <text class="form-label">地块描述</text>
            <textarea class="form-textarea" value="{{plotDescription}}" bindinput="onPlotDescriptionInput" placeholder="请输入地块相关信息..." maxlength="500" />
          </view>
          <view class="form-item">
            <text class="form-label">特殊要求</text>
            <textarea class="form-textarea" value="{{plotRequirements}}" bindinput="onPlotRequirementsInput" placeholder="请输入特殊要求..." maxlength="500" />
          </view>
        </view>
      </view>
    </view>

    <!-- 步骤4: 参考图上传 -->
    <view class="collapsible-section">
      <view class="collapsible-item {{expandedSections.reference ? 'expanded' : ''}}" bindtap="onToggleSection" data-section="reference">
        <view class="step-header">
          <text class="step-number">4</text>
          <text class="collapsible-title">参考图上传</text>
          <text class="step-status" wx:if="{{stepCompleted.reference}}">✓</text>
        </view>
        <t-icon name="{{expandedSections.reference ? 'chevron-down' : 'chevron-up'}}" size="32rpx" color="#8c7553" />
      </view>
      <view class="collapsible-content" wx:if="{{expandedSections.reference}}">
        <view class="upload-btn" bindtap="onUploadReference">
          <t-icon name="upload" size="36rpx" color="#8c7553" />
          <text>上传参考图片</text>
        </view>
        <view class="uploaded-images" wx:if="{{referenceImages.length > 0}}">
          <view class="image-item" wx:for="{{referenceImages}}" wx:key="index">
            <image class="uploaded-image" src="{{item}}" mode="aspectFill" />
            <view class="image-delete" bindtap="onDeleteReferenceImage" data-index="{{index}}">×</view>
          </view>
        </view>
        <view class="upload-hint">
          <text>可以上传多张参考图片，帮助AI更好地理解您的设计需求</text>
        </view>
      </view>
    </view>

    <!-- 步骤5: 自定义提示词 -->
    <view class="collapsible-section">
      <view class="collapsible-item {{expandedSections.prompt ? 'expanded' : ''}}" bindtap="onToggleSection" data-section="prompt">
        <view class="step-header">
          <text class="step-number">5</text>
          <text class="collapsible-title">自定义提示词（可选）</text>
          <text class="step-status" wx:if="{{stepCompleted.prompt}}">✓</text>
        </view>
        <t-icon name="{{expandedSections.prompt ? 'chevron-down' : 'chevron-up'}}" size="32rpx" color="#8c7553" />
      </view>
      <view class="collapsible-content" wx:if="{{expandedSections.prompt}}">
        <view class="plot-form">
          <view class="form-item">
            <text class="form-label">自定义提示词</text>
            <textarea class="form-textarea" value="{{customPrompt}}" bindinput="onCustomPromptInput" placeholder="可以输入自定义的AI提示词，更精确地描述您的设计需求..." maxlength="1000" />
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- AI生成设计按钮（四步都完成后显示） -->
  <view class="generate-button-wrapper" wx:if="{{allStepsCompleted}}">
    <button class="generate-button" bindtap="onGenerateDesign">AI生成设计</button>
  </view>
</view>