.tabbar-placeholder {
  width: 100%;
  height: 106rpx;
  padding: 0 0 env(safe-area-inset-bottom);
  box-sizing: content-box;
}

.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  padding: 0 0 env(safe-area-inset-bottom);
  box-sizing: border-box;
  background: #ffffff;
  transform: translateZ(0);
}

.tabbar {
  position: relative;
  width: 100vw;
  height: 106rpx;
  background: #ffffff;
  border-top: 1rpx solid rgba(209, 196, 180, 0.7);
  border-radius: 0;
  box-shadow: 0 -2rpx 12rpx rgba(94, 65, 47, 0.06);
  box-sizing: border-box;
  overflow: hidden;
}

.tabbar-background {
  display: block;
  width: 100%;
  height: 100%;
}

.tabbar-hitbox-layer {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
}

.tabbar-hitbox {
  flex: 1;
  height: 100%;
}
